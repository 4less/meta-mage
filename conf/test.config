// Small fixture: the two species already present under data/.
// Exercises the full genecall -> linclust -> counts -> score -> emit path
// and multi-rank aggregation on data you can eyeball.

params {
    genome_sheet = "${projectDir}/assets/test_genome_sheet.csv"
    outdir       = "${projectDir}/results_test"

    // relax thresholds a touch for the tiny fixture
    min_genomes_per_species = 5     // keep both fixture species (Clostridium has 7)
    min_clade_size          = 2
    max_out_prevalence      = 0.05
    max_markers_per_clade   = 500
}
