// Per-process resources. Bio-tool provisioning comes from the nf-core modules
// themselves (their own conda/container directives); local processes below are
// stdlib-python / coreutils, except DIVERSITY which needs mash.

process {
    cpus   = 1
    memory = 2.GB
    time   = 1.h

    withName: PYRODIGAL {
        cpus   = 1
        memory = 2.GB
    }

    // Per-genome scatter -> SLURM job arrays instead of one job per genome
    // (see params.array_size). array=0 disables it on the local executor, which
    // the test/local profiles set since local has no job-array support.
    withName: 'PYRODIGAL|REHEADER' {
        array = params.array_size
    }

    withName: 'MMSEQS_CREATEDB|MMSEQS_CREATETSV' {
        cpus   = 8
        memory = { 16.GB * task.attempt }
        time   = 12.h
    }

    // Whole-DB protein clustering -- memory-hungry; retry with more memory + time
    // on an OOM/kill (SLURM signals surface as exit 130-145), scaling per attempt.
    withName: 'MMSEQS_LINCLUST' {
        cpus          = 8
        memory        = { 64.GB * task.attempt }
        time          = { 24.h  * task.attempt }
        errorStrategy = { task.exitStatus in ((130..145) + [104]) ? 'retry' : 'finish' }
        maxRetries    = 3
    }

    // Nuc-vs-nuc all-CDS cross-mapping -- the heaviest mmseqs step; the global
    // all-CDS target makes it hungrier than clustering (128 GB, doubled again).
    withName: 'CROSSMAP' {
        cpus          = 8
        memory        = { 128.GB * task.attempt }
        time          = { 24.h   * task.attempt }
        errorStrategy = { task.exitStatus in ((130..145) + [104]) ? 'retry' : 'finish' }
        maxRetries    = 3
    }

    withName: 'BUILD_MANIFEST|REHEADER|COUNTS|SCORE|EMIT_REPS|SPECIFICITY|DIVERSITY|EMIT_DB|MARKER_ANI|NAKEDNESS' {
        // stdlib-python / coreutils only -- no external bio tools
        cpus   = 2
        memory = 4.GB
    }

    // Marker-vs-marker self search (nakedness). mmseqs like CROSSMAP but the
    // target is only the (tiny) marker set, so it needs far less than the all-CDS
    // search -- but still more than the 2 GB default, or its --split-memory-limit
    // floor is too small for mmseqs to load the DB. Retry on OOM/kill.
    withName: 'NAKEDNESS_SEARCH' {
        cpus          = 4
        memory        = { 16.GB * task.attempt }
        time          = { 4.h   * task.attempt }
        errorStrategy = { task.exitStatus in ((130..145) + [104]) ? 'retry' : 'finish' }
        maxRetries    = 2
    }

    // Low-marker diagnostics. Masking/report/ani-gap are stdlib-python; only
    // ANI_SKANI runs a bio tool (skani), so it gets the big allocation.
    withName: 'LOW_MARKER_MASKING|LOW_MARKER_REPORT|ANI_GAP|MASKING_REPORT' {
        cpus   = 2
        memory = { 6.GB * task.attempt }
    }
    withName: 'ANI_SKANI' {
        cpus          = 32
        memory        = { 64.GB * task.attempt }
        time          = { 8.h   * task.attempt }
        errorStrategy = { task.exitStatus in ((130..145) + [104]) ? 'retry' : 'finish' }
        maxRetries    = 2
    }
}
