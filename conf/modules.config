// nf-core convention: tool arguments live here via ext.args, not in process params.

process {

    withName: PYRODIGAL {
        // meta mode is robust across fragmentary MAGs
        ext.args   = '-p meta'
        // Distinct prefix: pyrodigal's CDS output is <prefix>.fna.gz, which must
        // NOT collide with the input genome <genome_id>.fna.gz (Nextflow excludes
        // input files from output matching, so a collision loses the output).
        ext.prefix = { "g${meta.idx}" }
        publishDir = [ path: { "${params.outdir}/genecall" }, mode: 'copy', enabled: false ]
    }

    withName: MMSEQS_CREATEDB {
        ext.prefix = 'proteinsdb'
    }

    withName: MMSEQS_LINCLUST_LOOSE {
        // Loose protein family definition (family-and-above scaffold).
        ext.args   = "--min-seq-id ${params.linclust_min_seq_id} -c ${params.linclust_coverage} --cov-mode ${params.linclust_cov_mode}"
        ext.prefix = 'linclust_loose'
    }

    withName: MMSEQS_LINCLUST_SPECIES {
        // Tight protein clustering; owns the species rank (== UniRef90 identity).
        ext.args   = "--min-seq-id ${params.linclust_min_seq_id_species} -c ${params.linclust_coverage} --cov-mode ${params.linclust_cov_mode}"
        ext.prefix = 'linclust_species'
    }

    withName: MMSEQS_CREATETSV_LOOSE {
        ext.prefix = 'clusters_loose'
        publishDir = [ path: { "${params.outdir}/linclust" }, mode: 'copy' ]
    }

    withName: MMSEQS_CREATETSV_SPECIES {
        ext.prefix = 'clusters_species'
        publishDir = [ path: { "${params.outdir}/linclust" }, mode: 'copy' ]
    }

    withName: 'SCORE|EMIT_DB' {
        publishDir = [ path: { "${params.outdir}/markers" }, mode: 'copy' ]
    }
}
