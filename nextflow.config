// meta-mage: clade-specific marker gene discovery
// DSL2 pipeline. Scales the per-species pangenome logic to a cross-clade,
// all-ranks, classifier-oriented marker database over ~800k genomes.

nextflow.enable.dsl = 2

manifest {
    name            = 'meta-mage/markers'
    description      = 'Clade-specific marker gene extraction across GTDB'
    author          = '4less'
    nextflowVersion  = '>=24.04.0'
    version          = '0.1.0'
}

params {
    help         = false

    // --- input ---
    genome_sheet = null            // CSV: accession, gtdb_lineage (d__..;..;s__..), path
    outdir       = "${projectDir}/results"

    // GTDB metadata TSV(.gz) for CheckM2 completeness -> completeness-weighted core
    // prevalence (a genome missing a gene subtracts only its completeness). Unset =
    // every genome weighted as complete (old unweighted behaviour).
    gtdb_metadata = null

    // --- prefilter ---
    // Drop genomes whose species is represented by fewer than this many genomes,
    // before indexing. Under-sampled species make within-species prevalence
    // meaningless and pollute higher-rank clade sizes. 1 = keep everything.
    min_genomes_per_species = 10

    // --- gene calling (pyrodigal) ---
    prodigal_mode = 'meta'         // 'meta' is robust across fragmentary MAGs

    // --- cluster scheduling ---
    // The per-genome scatter (PYRODIGAL, REHEADER) is one task per genome. On a
    // grid executor, submit them as SLURM job arrays of this many tasks instead
    // of one job per genome (e.g. 7751 genomes -> ~78 array jobs at 100), which
    // spares the scheduler thousands of tiny submissions. 0 disables batching
    // and is REQUIRED on the local executor (which has no job-array support);
    // the test/local profiles set it to 0. Tune with --array_size.
    array_size = 100

    // --- vocabulary (mmseqs2 linclust), rank-aware ---
    // Protein-space clustering defines the gene-family vocabulary. Two passes:
    //  * loose (0.5) builds the family-and-above scaffold. Do NOT drop to
    //    nucleotide here or higher-rank homologs shatter into separate clusters.
    //  * species (0.9, == UniRef90 / ChocoPhlAn) keeps paralogous/sister-species
    //    genes apart so species-rank specificity survives. Species-rank
    //    counts/scoring/emission route through this tight clustering; every
    //    higher rank routes through the loose one.
    linclust_min_seq_id         = 0.5
    linclust_min_seq_id_species = 0.9
    linclust_coverage           = 0.8
    linclust_cov_mode           = 0

    // --- specificity thresholds (classifier-biased: strict) ---
    min_in_prevalence  = 0.80      // marker present in >= this fraction of in-clade genomes
    max_out_prevalence = 0.02      // marker present in <= this fraction of outside genomes
    min_clade_size     = 3         // skip clades smaller than this
    max_markers_per_clade = 100    // cap per clade (best-scoring kept): ~100 genes/species
    min_gene_len       = 300       // drop marker CDS shorter than this (bp); 0 = off
    // Rank score = in_prevalence * (1 - out_prevalence) ** score_out_exp.
    score_out_exp      = 1.0       // >1 penalises off-target prevalence more steeply

    // --- report ---
    // Prevalence at/above which a gene family is called "core" for the HTML
    // report's per-species funnel (pangenome -> core -> marker). Reporting-only:
    // does not affect marker selection. Defaults to the marker in-prevalence.
    core_prevalence    = 0.80

    // --- nucleotide payload / diversity ---
    div_kmer = 21                  // k-mer size for within-clade nucleotide distance

    // --- specificity guard (nucleotide cross-mapping) ---
    // MetaPhlAn's final uniqueness check. After selection, drop any marker whose
    // nucleotide sequence also occurs in a genome OUTSIDE its target clade at
    // read-mapping identity -- such a marker would steal reads from off-target
    // taxa. Target universe = species-rep CDS (reps.ffn). Set false to skip.
    specificity          = true
    specificity_min_id   = 0.95    // nucleotide identity of an off-target hit
    specificity_min_aln  = 100     // bp; ~a read-length window that would cross-map
    specificity_max_seqs = 4000    // mmseqs per-query target cap (raise for huge clades)

    // --- per-species within-marker ANI (report boxplots) ---
    // For each top-scoring marker, pairwise nucleotide DISTANCE among its copies
    // across the species' genomes (how conserved the marker is within-species),
    // at three filtering stages (specific-N -> post-crossmap -> post-recovery).
    marker_ani_cap        = 200    // markers per species per stage (x-axis cap)
    marker_ani_max_copies = 60     // genomes sampled per marker (bounds cost)
    marker_ani_kmer       = 21     // k for the mash-style distance estimate
    marker_ani_dist_max   = 0.2    // boxplot y-axis max (nucleotide distance)

    // Mask recovery: a marker that cross-maps only over PART of its length is kept
    // (whole, unmasked) if masking the cross-mapping stretches still leaves a clean
    // window >= mask_recovery_min_clean bp AND <= mask_recovery_max_masked_frac of
    // the gene is masked. Off = legacy binary guard. Recovered markers count as
    // final markers. Masking is done against the same all-genome CDS the guard used.
    mask_recovery                  = true
    mask_recovery_min_clean        = 300   // min clean (un-cross-mapping) window, bp
    mask_recovery_max_masked_frac  = 0.5   // at most half the gene may be masked

    // --- low-marker diagnostics ---
    // Species that end with FEWER than this many final markers are diagnosed:
    //   1. crossmap masking -- are the dropped markers wholly cross-mapping, or
    //      could masking a slice rescue them? (assess_crossmap_masking.py)
    //   2. ANI species gap  -- 6 within- vs between-species pairwise ANI in
    //      the species' genus: is within always tighter than between, or do the
    //      species overlap (a re-merge signal)? (ani_gap.py)
    // Set 0 to disable the whole diagnostics stage.
    low_marker_threshold = 50
    low_marker_ani       = 95.0    // ANI (%) flagged as a same-species merge candidate
    low_marker_min_af    = 0.5     // min skani align fraction for a pair to count
    masking_min_survivor = 200     // bp that must remain clade-unique after masking
                                   // for a dropped marker to count as "rescuable"

    // --- reporting ---
    tracedir = "${params.outdir}/pipeline_info"
}

profiles {
    test    { includeConfig 'conf/test.config' }
    conda   { conda.enabled = true;  conda.useMamba = true }
    docker  { docker.enabled = true }
    slurm   { process.executor = 'slurm'; process.queue = 'compute' }
    local   { process.executor = 'local'; params.array_size = 0 }  // local has no job arrays

    // M3 Research Center HPC. Pulls nf-core's self-contained site config
    // directly (no nfcore_custom.config needed). Fetched at launch — if the
    // head node is offline, clone nf-core/configs and point this at the local
    // conf/m3c.config instead.
    m3c     { includeConfig 'https://raw.githubusercontent.com/nf-core/configs/master/conf/m3c.config' }
}

includeConfig 'conf/base.config'
includeConfig 'conf/modules.config'

timeline { enabled = true; file = "${params.tracedir}/timeline.html"; overwrite = true }
report   { enabled = true; file = "${params.tracedir}/report.html";   overwrite = true }
trace    { enabled = true; file = "${params.tracedir}/trace.txt";     overwrite = true }
// Workflow DAG rendered to PDF (needs graphviz `dot`; falls back to .html/.mmd if absent).
dag      { enabled = true; file = "${params.tracedir}/pipeline_dag.pdf"; overwrite = true }
