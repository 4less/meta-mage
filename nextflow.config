// meta-mage: clade-specific marker gene discovery
// DSL2 pipeline. Scales the per-species pangenome logic to a cross-clade,
// all-ranks, classifier-oriented marker database over ~800k genomes.

nextflow.enable.dsl = 2

manifest {
    name            = 'meta-mage/markers'
    description      = 'Clade-specific marker gene extraction across GTDB'
    author          = '4less'
    nextflowVersion  = '>=24.04.0'
    version          = '0.1.0'
}

params {
    help         = false

    // --- input ---
    genome_sheet = null            // CSV: accession, gtdb_lineage (d__..;..;s__..), path
    outdir       = "${projectDir}/results"

    // --- prefilter ---
    // Drop genomes whose species is represented by fewer than this many genomes,
    // before indexing. Under-sampled species make within-species prevalence
    // meaningless and pollute higher-rank clade sizes. 1 = keep everything.
    min_genomes_per_species = 10

    // --- gene calling (pyrodigal) ---
    prodigal_mode = 'meta'         // 'meta' is robust across fragmentary MAGs

    // --- vocabulary (mmseqs2 linclust), rank-aware ---
    // Protein-space clustering defines the gene-family vocabulary. Two passes:
    //  * loose (0.5) builds the family-and-above scaffold. Do NOT drop to
    //    nucleotide here or higher-rank homologs shatter into separate clusters.
    //  * species (0.9, == UniRef90 / ChocoPhlAn) keeps paralogous/sister-species
    //    genes apart so species-rank specificity survives. Species-rank
    //    counts/scoring/emission route through this tight clustering; every
    //    higher rank routes through the loose one.
    linclust_min_seq_id         = 0.5
    linclust_min_seq_id_species = 0.9
    linclust_coverage           = 0.8
    linclust_cov_mode           = 0

    // --- specificity thresholds (classifier-biased: strict) ---
    min_in_prevalence  = 0.90      // marker present in >= this fraction of in-clade genomes
    max_out_prevalence = 0.02      // marker present in <= this fraction of outside genomes
    min_clade_size     = 3         // skip clades smaller than this
    max_markers_per_clade = 200    // cap per clade to keep the DB balanced

    // --- nucleotide payload / diversity ---
    div_kmer = 21                  // k-mer size for within-clade nucleotide distance

    // --- specificity guard (nucleotide cross-mapping) ---
    // MetaPhlAn's final uniqueness check. After selection, drop any marker whose
    // nucleotide sequence also occurs in a genome OUTSIDE its target clade at
    // read-mapping identity -- such a marker would steal reads from off-target
    // taxa. Target universe = species-rep CDS (reps.ffn). Set false to skip.
    specificity          = true
    specificity_min_id   = 0.95    // nucleotide identity of an off-target hit
    specificity_min_aln  = 100     // bp; ~a read-length window that would cross-map
    specificity_max_seqs = 4000    // mmseqs per-query target cap (raise for huge clades)

    // --- reporting ---
    tracedir = "${params.outdir}/pipeline_info"
}

profiles {
    test    { includeConfig 'conf/test.config' }
    conda   { conda.enabled = true;  conda.useMamba = true }
    docker  { docker.enabled = true }
    slurm   { process.executor = 'slurm'; process.queue = 'compute' }
    local   { process.executor = 'local' }
}

// nf-core shared institutional configs — enables `-profile m3c` (MASSIVE/M3)
// and every other site profile, the same way real nf-core pipelines get them.
// Fetched at launch; point custom_config_base at a local clone if the head node
// has no internet (see nf-core/configs offline instructions).
params {
    custom_config_version = 'master'
    custom_config_base    = "https://raw.githubusercontent.com/nf-core/configs/${params.custom_config_version}"
}
try {
    includeConfig "${params.custom_config_base}/nfcore_custom.config"
} catch (Exception e) {
    System.err.println("WARNING: Could not load nf-core/config profiles: ${params.custom_config_base}/nfcore_custom.config")
}

includeConfig 'conf/base.config'
includeConfig 'conf/modules.config'

timeline { enabled = true; file = "${params.tracedir}/timeline.html"; overwrite = true }
report   { enabled = true; file = "${params.tracedir}/report.html";   overwrite = true }
trace    { enabled = true; file = "${params.tracedir}/trace.txt";     overwrite = true }
